# ============================================================
#  AirdropAgent — Local Environment Variables
#  File: .env.example
#
#  USAGE:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in values in .env
#    3. The .env file is in .gitignore — NEVER pushed to GitHub
#
#  For GitHub Actions: add these values in
#  GitHub → Settings → Secrets and variables → Actions
# ============================================================

# ── LLM ──────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Discord Notifications ─────────────────────────────────────
# Webhook URL to send notifications to your Discord channel
DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# ── Telegram Notifications ────────────────────────────────────
# Bot created via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABCdef...
TELEGRAM_CHAT_ID=123456789

# ── Telegram Tracker (read project channels) ──────────────────
# From https://my.telegram.org → API development tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
# Generated once via: python scripts/generate_session.py
TELEGRAM_SESSION_STRING=1Bv1BmABCdef...

# ── Wallet Scorer ─────────────────────────────────────────────
# ⚠️  NEVER put wallet addresses in settings.yaml (public file)
# Comma-separated list of wallet addresses to score
WALLET_ADDRESSES=0xYourWalletAddress1,0xYourWalletAddress2

# ── Discord Tracker (optional — future phase) ─────────────────
# DISCORD_USER_TOKEN=...
