# ============================================================
#  AirdropAgent — Variables d'environnement locales
#  Fichier : .env.example
#
#  UTILISATION :
#    1. Copie ce fichier : cp .env.example .env
#    2. Remplis les valeurs dans .env
#    3. Le fichier .env est dans .gitignore — jamais pushé
#
#  Pour GitHub Actions : ajoute ces valeurs dans
#  GitHub → Settings → Secrets and variables → Actions
# ============================================================

# ── LLM ──────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Notifications Discord ─────────────────────────────────────
# Webhook pour envoyer les notifications dans ton salon Discord
DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# ── Notifications Telegram ────────────────────────────────────
# Bot créé via @BotFather
TELEGRAM_BOT_TOKEN=123456:ABCdef...
TELEGRAM_CHAT_ID=123456789

# ── Telegram Tracker (lecture canaux projets) ─────────────────
# Depuis https://my.telegram.org → API development tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
# Généré une seule fois via : python scripts/generate_session.py
TELEGRAM_SESSION_STRING=1Bv1BmABCdef...

# ── Wallets à scorer ──────────────────────────────────────────
# ⚠️  NE PAS mettre dans settings.yaml (fichier public)
# Liste d'adresses séparées par des virgules
WALLET_ADDRESSES=0xTonAdresseWallet1,0xTonAdresseWallet2

# ── Discord Tracker (optionnel — Phase future) ────────────────
# DISCORD_USER_TOKEN=...
